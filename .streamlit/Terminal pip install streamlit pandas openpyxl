import streamlit as st
import pandas as pd

st.title("📞 دليل شركات دبي")

# هنا نطلب من البرنامج يقرأ ملف الإكسل حقك
# (تأكد أن اسم الملف هنا نفس اسم ملفك بالضبط)
file_name = "companies.xlsx" 

try:
    df = pd.read_excel(file_name)
    search = st.text_input("اكتب اسم الشركة هنا للبحث:")
    
    if search:
        # يفلتر الجدول ويطلع لك بس الشركة اللي تبيها
        result = df[df.astype(str).apply(lambda x: x.str.contains(search, case=False)).any(axis=1)]
        st.write(result)
    else:
        st.write("هذي كل الشركات اللي عندك:")
        st.write(df)
except:
    st.error("يا بطل، تأكد أن ملف الإكسل موجود في نفس المجلد!")
